include ./workspace.conf
include ./theme.conf
include ./actions.conf
include ./misc/*

# Autotiling - AUR autotiling
exec_always autotiling

# Opacity for unfocused windows.
exec_always ~/.config/sway/scripts/inactive-windows-transparency.py

# Auto lock
set $lock swaylock -f -C ~/.config/swaylock/config

exec_always swayidle -w \
    timeout 600 '$lock' \
    timeout 660 'swaymsg "output * dpms off"' \
    resume 'swaymsg "output * dpms on"' \
    before-sleep '$lock'

# Status Bar:
bar {
    swaybar_command waybar
}

# Floating applications

	for_window [app_id="zoom"] floating enable



